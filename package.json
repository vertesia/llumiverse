{
    "name": "@llumiverse/parent",
    "version": "1.3.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm -r build",
        "bump": "pnpm exec wst bump minor",
        "check": "pnpm exec biome check .",
        "check:write": "pnpm exec biome check --write .",
        "ci:local": "pnpm run ci:renovate && pnpm run check && pnpm run build && pnpm run typecheck:test && pnpm run test",
        "ci:renovate": "npx --yes --package renovate -- renovate-config-validator --strict",
        "format": "pnpm exec biome format --write .",
        "format:check": "pnpm exec biome format .",
        "lint": "pnpm exec biome lint",
        "lint:actions": "scripts/run-actionlint.sh",
        "lint:fix": "pnpm exec biome lint --write",
        "prepare": "cp ./README.md ./core/ && cp ./README.md ./drivers/ && git config core.hooksPath .githooks 2>/dev/null || true",
        "release": "pnpm -r publish --access public",
        "test": "pnpm -r test",
        "typecheck:test": "pnpm -r typecheck:test"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.11",
        "cross-spawn": "^7.0.6",
        "npm-ws-tools": "^0.3.0",
        "rollup": "^4.61.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "packageManager": "pnpm@11.5.0"
}
